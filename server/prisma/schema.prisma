generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Akun {
  id        String   @id
  nama      String
  username  String   @unique
  // bcrypt hash, never plaintext (see DATA-02)
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Kota {
  nama             String             @id
  kapasitas        Int
  permintaan       Permintaan[]
  keputusan        Keputusan[]
  riwayatKeputusan RiwayatKeputusan[]
}

model Permintaan {
  id                String   @id
  kotaNama          String
  kota              Kota     @relation(fields: [kotaNama], references: [nama])
  tanggalPermintaan String
  tanggalInput      String
  jumlahPermintaan  Float
  keterangan        String?
  createdAt         DateTime @default(now())

  @@index([kotaNama])
}

model Keputusan {
  id                   String    @id
  kotaTujuanNama       String
  kotaTujuan           Kota      @relation(fields: [kotaTujuanNama], references: [nama])
  volumeTbs            Float
  tanggalKeputusan     String
  diputuskanOleh       String
  status               String
  armada               String?
  eta                  String?
  waktuMenunggu        DateTime?
  waktuDalamPengiriman DateTime?
  waktuSelesai         DateTime?
  waktuDibatalkan      DateTime?

  @@index([kotaTujuanNama])
}

model RiwayatKeputusan {
  id                   String    @id
  kotaTujuanNama       String
  kotaTujuan           Kota      @relation(fields: [kotaTujuanNama], references: [nama])
  volumeTbs            Float
  tanggalKeputusan     String
  diputuskanOleh       String
  status               String
  armada               String?
  eta                  String?
  waktuMenunggu        DateTime?
  waktuDalamPengiriman DateTime?
  waktuSelesai         DateTime?
  waktuDibatalkan      DateTime?

  @@index([kotaTujuanNama])
}

model ActivityLog {
  id    String   @id
  aktor String
  role  String
  aksi  String
  waktu DateTime @default(now())
}

model Notifikasi {
  id     String   @id
  judul  String
  pesan  String
  tipe   String
  dibaca Boolean  @default(false)
  waktu  DateTime @default(now())
}

// Singleton settings row holding the current TBS stock value. Fixed id
// ("singleton") enforces there is ever only one row — the canonical home
// for the value src/store.js keeps in state.stokTbs (getStokTbs/setStokTbs).
model Stok {
  id      String @id @default("singleton")
  stokTbs Int
}

// Target KPI yang ditetapkan Manajer Distribusi (management by objectives).
// Singleton seperti Stok. Nilai-nilai ini dipakai misService sebagai ambang
// keputusan (status stok, eskalasi keputusan) dan pembanding realisasi KPI —
// menggantikan konstanta hardcoded.
model TargetKpi {
  id               String @id @default("singleton")
  targetPemenuhan  Int    @default(80) // % keputusan berstatus selesai
  targetWaktuKirim Float  @default(2) // hari rata-rata pengiriman
  targetUtilisasi  Int    @default(70) // % utilisasi kapasitas rata-rata
  minHariPasokan   Int    @default(14) // stok di bawah ini = perhatian; setengahnya = kritis
  maxHariEskalasi  Int    @default(3) // keputusan menunggu lebih lama dari ini dieskalasi
}

// Snapshot KPI harian — satu baris per tanggal (unique). Direkam otomatis
// oleh sinkronNotifikasiMis saat dashboard Manajer dimuat, menjadi sumber
// grafik Tren Kinerja lintas waktu (ciri pelaporan berkala MIS).
model KpiSnapshot {
  id                  Int      @id @default(autoincrement())
  tanggal             String   @unique // YYYY-MM-DD
  tingkatPemenuhan    Int
  keputusanAktif      Int
  rataWaktuPengiriman Float?
  utilisasiKapasitas  Int
  stokTbs             Int
  totalPermintaanTon  Float
  createdAt           DateTime @default(now())
}
